<?xml version="1.0" encoding="UTF-8"?>

<configuration>
    <property
            name="LOG_PATH"
            value="logs"/>
    <property
            name="LOG_PATTERN"
            value="%d{dd/MM/yyyy HH:mm:ss} | %-5level | %-45logger{45} | %msg%n"/>
    <appender
            name="CONSOLE"
            class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>
                ${LOG_PATTERN}
            </pattern>
        </encoder>

    </appender>
    <appender
            name="FILE"
            class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>
            ${LOG_PATH}/integration-engine.log
        </file>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <fileNamePattern>
                ${LOG_PATH}/integration-engine-%d{yyyy-MM-dd}.log
            </fileNamePattern>

            <maxHistory>
                30
            </maxHistory>

            <totalSizeCap>
                1GB
            </totalSizeCap>

        </rollingPolicy>

        <encoder>
            <pattern>
                ${LOG_PATTERN}
            </pattern>
        </encoder>

    </appender>
    <logger
            name="org.springframework"
            level="WARN"/>

    <logger
            name="org.apache"
            level="WARN"/>

    <logger
            name="org.hibernate"
            level="WARN"/>

    <logger
            name="br.com.buni.integration.core"
            level="INFO"/>
    <root level="INFO">

        <appender-ref ref="CONSOLE"/>

        <appender-ref ref="FILE"/>

    </root>

</configuration>